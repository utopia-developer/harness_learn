{
  "name": "harness-learn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "npm run build",
    "dev:api": "npm run build && node dist/apps/api/src/index.js",
    "dev:web": "npm run build && node dist/apps/web/dev-server.js",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\"",
    "test:e2e": "npm run build && node --test \"dist/tests/e2e/**/*.test.js\"",
    "test:web": "npm run build && node --test \"dist/tests/web/**/*.test.js\"",
    "start": "node dist/src/cli/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
