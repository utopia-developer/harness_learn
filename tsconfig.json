{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true
  },
  "include": [
    "apps/api/src/**/*.ts",
    "apps/web/dev-server.ts",
    "apps/web/src/**/*.ts",
    "src/**/*.ts",
    "packages/**/*.ts",
    "tests/**/*.ts"
  ]
}
